{
  "expo": {
    "name": "Phone_App",
    "slug": "Phone_App",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "phoneapp",
    "platforms": [
      "android"
    ],
    "newArchEnabled": true,
    "android": {
      "package": "com.tonentreprise.phoneapp",
      "versionCode": 1
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ]
    ]
  }
}
